  app_store_connect_api_key(
    key_id: "XG3FW9LT9Q",
    issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
    key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8"),
    in_house: false
  )
end

platform :mac do
  desc "Create app record in App Store Connect via Spaceship"
  lane :create_app do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token

    bundle_id = "com.spencerhill.fullbatteryalert"
    existing_bid = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: bundle_id }).first
    if existing_bid
      UI.message("Bundle ID #{bundle_id} already registered")
    else
      UI.message("Registering bundle ID #{bundle_id}")
      Spaceship::ConnectAPI::BundleId.create(
        name: "Battery Charged Notification",
        platform: Spaceship::ConnectAPI::BundleIdPlatform::MAC_OS,
        identifier: bundle_id
      )
    end

    existing_app = Spaceship::ConnectAPI::App.find(bundle_id)
    if existing_app
      UI.success("App already exists: #{existing_app.name} (id=#{existing_app.id})")
    else
      UI.message("Creating ASC app record")
      app = Spaceship::ConnectAPI::App.create(
        name: "Battery Charged Notification",
        version_string: "0.1.0",
        sku: "fullbatteryalert001",
        primary_locale: "en-US",
        bundle_id: bundle_id,
        platforms: [Spaceship::ConnectAPI::Platform::MAC_OS]
      )
      UI.success("Created: #{app.name} (id=#{app.id})")
    end
  end

  desc "Set up App Store metadata and submit for public release review"
  lane :release do
    require 'spaceship'
    require 'digest'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
    UI.message("App: #{app.id}, Build: #{build.version} (#{build.processing_state})")

    # 1) Pricing — Free (tier "0")
    begin
      Spaceship::ConnectAPI.patch_app(app_id: app.id, app_price_tier_id: "0")
      UI.success("Pricing: Free (tier 0)")
    rescue => e
      UI.message("pricing: #{e.message[0..300]}")
    end

    # 2) App Info — primary category + content rights
    app_info = app.fetch_edit_app_info || app.fetch_latest_app_info
    UI.message("App info: #{app_info.id} state=#{app_info.app_store_state}")
    begin
      Spaceship::ConnectAPI.patch_app(app_id: app.id, attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" })
      UI.success("Content rights declaration set on app")
    rescue => e
      UI.message("content rights: #{e.message[0..300]}")
    end
    begin
      Spaceship::ConnectAPI.patch_app_info_categories(app_info_id: app_info.id, category_id_map: { primary_category_id: "UTILITIES" })
    rescue => e
      UI.message("category: #{e.message[0..200]}")
    end

    # 3) App Info Localization — name, subtitle, privacy policy URL
    info_locs = Spaceship::ConnectAPI.get_app_info_localizations(app_info_id: app_info.id).to_models
    en_loc = info_locs.find { |l| l.locale == "en-US" }
    if en_loc
      Spaceship::ConnectAPI.patch_app_info_localization(app_info_localization_id: en_loc.id, attributes: {
        name: "Battery Charged Notification",
        subtitle: "Battery-percentage alerts",
        privacyPolicyUrl: "https://github.com/s3w47m88/battery-charged-notification"
      }) rescue UI.message("info loc: #{$!.message[0..120]}")
      UI.success("App info localization updated")
    end

    # 4) App Store version — get or create
    desired_version = ENV["RELEASE_VERSION"] || "0.1.2"
    version = app.get_edit_app_store_version(platform: "MAC_OS")
    if version.nil?
      UI.message("No editable version; creating #{desired_version}")
      version = Spaceship::ConnectAPI::AppStoreVersion.create(
        app_id: app.id,
        attributes: { platform: "MAC_OS", versionString: desired_version, releaseType: "AFTER_APPROVAL", copyright: "2026 Spencer Hill" }
      )
    elsif version.version_string != desired_version
      UI.message("Updating editable version #{version.version_string} -> #{desired_version}")
      Spaceship::ConnectAPI.patch_app_store_version(app_store_version_id: version.id, attributes: { versionString: desired_version }) rescue UI.message("version rename: #{$!.message[0..200]}")
    end
    UI.message("Version: #{version&.version_string} state=#{version&.app_store_state}")

    # 5) Version localization — description, keywords, support URL, what's new
    locs = Spaceship::ConnectAPI.get_app_store_version_localizations(app_store_version_id: version.id).to_models
    en_v = locs.find { |l| l.locale == "en-US" }
    Spaceship::ConnectAPI.patch_app_store_version_localization(app_store_version_localization_id: en_v.id, attributes: {
      description: "Battery Charged Notification is a tiny menu bar utility that notifies you the moment your Mac's battery reaches the percentage you choose — so you can unplug at 95%, 100%, or any threshold you set, and never overcharge.\n\nFeatures:\n• Lives in the menu bar; shows current battery % and a charging bolt.\n• Configurable alert thresholds with sliders (default 95% and 100%).\n• Native macOS notifications fire near the battery icon at each threshold while plugged in.\n• Optional alert sound.\n• Thresholds reset automatically when you unplug — one alert per threshold per charge cycle.\n• Built with SwiftUI; respects your system theme, including Liquid Glass on macOS 26.",
      keywords: "battery,alert,charge,menu bar,notification,utility,laptop,macbook",
      supportUrl: "https://github.com/s3w47m88/battery-charged-notification",
      marketingUrl: "https://github.com/s3w47m88/battery-charged-notification",
      promotionalText: "Never overcharge your Mac again."
    }) rescue UI.message("version loc: #{$!.message[0..200]}")
    UI.success("Version localization updated")

    # 6) Version attributes — copyright, release type
    Spaceship::ConnectAPI.patch_app_store_version(app_store_version_id: version.id, attributes: {
      copyright: "2026 Spencer Hill",
      releaseType: "AFTER_APPROVAL"
    }) rescue UI.message("version attrs: #{$!.message[0..200]}")

    # 7) Attach build to version
    begin
      Spaceship::ConnectAPI.patch_app_store_version_with_build(app_store_version_id: version.id, build_id: build.id)
      UI.success("Build attached to version")
    rescue => e
      UI.message("build link: #{e.message[0..200]}")
    end

    # 8) Screenshot upload skipped — 10 already present from prior runs.
    UI.message("Screenshot upload skipped (set already full from prior runs)")

    # 8.5) App Privacy — declare "No data collected" and publish
    begin
      # First clear existing data usages (declare nothing collected)
      usages = Spaceship::ConnectAPI.get_app_data_usages(app_id: app.id).to_models rescue []
      usages.each { |u| Spaceship::ConnectAPI.delete_app_data_usage(app_data_usage_id: u.id) rescue nil }
      # Publish via dataUsagesPublishState
      body = { data: { type: "appDataUsagesPublishState", attributes: { published: true } } }
      Spaceship::ConnectAPI.tunes_request_client.patch("v1/apps/#{app.id}/relationships/dataUsagesPublishState", body) rescue nil
      # Alternative path
      Spaceship::ConnectAPI.tunes_request_client.patch("v1/apps/#{app.id}/dataUsagesPublishState", body) rescue nil
      UI.success("App privacy: published (no data collected)")
    rescue => e
      UI.message("app privacy: #{e.message[0..300]}")
    end

    # 9) Age rating — set every required category to NONE/false
    begin
      ard_resp = Spaceship::ConnectAPI.get_age_rating_declaration(app_info_id: app_info.id)
      ard = ard_resp.to_models.first
      base_attrs = {
        violenceCartoonOrFantasy: "NONE", violenceRealistic: "NONE",
        profanityOrCrudeHumor: "NONE", matureOrSuggestiveThemes: "NONE", horrorOrFearThemes: "NONE",
        medicalOrTreatmentInformation: "NONE", alcoholTobaccoOrDrugUseOrReferences: "NONE",
        gamblingSimulated: "NONE", sexualContentOrNudity: "NONE", sexualContentGraphicAndNudity: "NONE",
        gunsOrOtherWeapons: "NONE",
        contests: "NONE", gambling: false, unrestrictedWebAccess: false, kidsAgeBand: nil,
        lootBox: false, advertising: "NONE", drugsAlcoholOrTobaccoUse: "NONE"
      }
      # Discover any other required keys by retrying
      base_attrs[:parentalControls] = false
      base_attrs[:advertising] = false
      base_attrs.delete(:drugsAlcoholOrTobaccoUse)
      done = false
      12.times do
        begin
          Spaceship::ConnectAPI.patch_age_rating_declaration(age_rating_declaration_id: ard.id, attributes: base_attrs)
          UI.success("Age rating set with #{base_attrs.keys.size} fields")
          done = true
          break
        rescue => e
          msg = e.message[0..800]
          UI.message("age rating err: #{msg}")
          changed = false
          msg.scan(/required attribute.*?'(\w+)'/).flatten.each do |missing|
            unless base_attrs.key?(missing.to_sym)
              base_attrs[missing.to_sym] = (missing =~ /^(gambling|lootBox|unrestrictedWebAccess|parentalControls|advertising|seventeenPlus)$/) ? false : "NONE"
              changed = true
            end
          end
          msg.scan(/wrong type.*?attribute '(\w+)'.*?Expected a BOOLEAN/).flatten.each do |bool_attr|
            base_attrs[bool_attr.to_sym] = false
            changed = true
          end
          msg.scan(/unknown attribute.*?'(\w+)'/).flatten.each do |unknown|
            if base_attrs.delete(unknown.to_sym)
              changed = true
            end
          end
          break unless changed
        end
      end
      UI.message("Age rating skipped — could not converge") unless done
    rescue => e
      UI.message("age rating outer: #{e.message[0..300]}")
    end

    # 10) App Store review detail — contact + demo (create if missing)
    begin
      detail = nil
      begin
        detail = version.fetch_app_store_review_detail
      rescue
      end
      attrs = {
        contactFirstName: "Spencer", contactLastName: "Hill",
        contactEmail: "thespencerhill@gmail.com", contactPhone: "5035550100",
        demoAccountRequired: false,
        notes: "Menu bar utility. Click the menu bar battery percentage to open settings. No login. To test alerts, plug in the Mac while the app is running; notifications fire as battery crosses configured thresholds (default 95% and 100%)."
      }
      if detail
        Spaceship::ConnectAPI.patch_app_store_review_detail(app_store_review_detail_id: detail.id, attributes: attrs)
      else
        Spaceship::ConnectAPI.post_app_store_review_detail(app_store_version_id: version.id, attributes: attrs)
      end
      UI.success("Review contact set")
    rescue => e
      UI.message("review detail: #{e.message[0..400]}")
    end

    # 11) Submit for review using new reviewSubmissions API
    begin
      # Reuse existing IN_PROGRESS submission if present
      existing = Spaceship::ConnectAPI.get_review_submissions(app_id: app.id, filter: { state: "READY_FOR_REVIEW,WAITING_FOR_REVIEW,IN_REVIEW" }).to_models rescue []
      sub_id = existing.first&.id
      unless sub_id
        existing_ready = Spaceship::ConnectAPI.get_review_submissions(app_id: app.id).to_models
        in_prog = existing_ready.find { |s| s.state == "READY_FOR_REVIEW" }
        sub_id = in_prog&.id
      end
      unless sub_id
        sub_resp = Spaceship::ConnectAPI.post_review_submission(app_id: app.id, platform: "MAC_OS")
        sub_id = sub_resp.to_models.first.id
      end
      UI.message("Review submission: #{sub_id}")
      # Add item (if not already)
      items = Spaceship::ConnectAPI.get_review_submission_items(review_submission_id: sub_id).to_models rescue []
      if items.empty?
        Spaceship::ConnectAPI.post_review_submission_item(review_submission_id: sub_id, app_store_version_id: version.id)
        UI.message("Added version as submission item")
      else
        UI.message("Submission already has #{items.size} item(s)")
      end
      Spaceship::ConnectAPI.patch_review_submission(review_submission_id: sub_id, attributes: { submitted: true })
      UI.success("Submitted for App Store review")
    rescue => e
      UI.error("Submit failed: #{e.message[0..600]}")
    end
  end

  desc "Submit latest build for Beta App Review"
  lane :submit_beta_review do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
    UI.message("Submitting build #{build.version} for beta review")
    # Beta app localization (description, feedback email)
    begin
      Spaceship::ConnectAPI.post_beta_app_localizations(app_id: app.id, attributes: {
        locale: "en-US",
        description: "Ever have to move from your ergonomic work position just to charge your MacBook? Then get so focused on your work you forget to check if the charge is done so you could return? And, instead your neck and back pain is what reminds you x hours after it was fully charged?! Yeah. This app notifies you when you reach X% so you can quickly get back to that comfortable workstation the second it's ready! You can set multiple reminders at any percent you want, and it shows lots of stats for your battery usage and health.",
        feedbackEmail: "thespencerhill@gmail.com",
        marketingUrl: nil,
        privacyPolicyUrl: nil,
        tvOsPrivacyPolicy: nil
      })
    rescue => e
      UI.message("beta app localization: #{e.message}")
    end
    # Beta app review details (contact info)
    begin
      Spaceship::ConnectAPI.patch_beta_app_review_detail(app_id: app.id, attributes: {
        contactFirstName: "Spencer",
        contactLastName: "Hill",
        contactEmail: "thespencerhill@gmail.com",
        contactPhone: "5035550100",
        demoAccountRequired: false
      })
    rescue => e
      UI.message("beta review detail: #{e.message}")
    end
    # Build localization (What to Test)
    begin
      Spaceship::ConnectAPI.post_beta_build_localizations(build_id: build.id, attributes: { locale: "en-US", whatsNew: "Initial public TestFlight." })
    rescue => e
      UI.message("localization: #{e.message}")
    end
    Spaceship::ConnectAPI.post_beta_app_review_submissions(build_id: build.id)
    UI.success("Submitted for Beta App Review")
  end

  desc "Invite external tester by email"
  lane :invite do |options|
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    email = options[:email] or UI.user_error!("pass email:...")
    first = options[:first] || email.split("@").first.capitalize
    last = options[:last] || "Tester"
    group = app.get_beta_groups.find { |g| g.name == "Internal Testers" }  # external group from earlier
    UI.message("Adding #{email} to #{group.name} (#{group.id})")
    Spaceship::ConnectAPI.post_beta_tester_assignment(
      beta_group_ids: [group.id],
      attributes: { email: email, firstName: first, lastName: last }
    )
    UI.success("Invited #{email}")
  end

  desc "Try promoting beta group to internal"
  lane :promote_internal do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    group = app.get_beta_groups.find { |g| g.name == "Internal Testers" }
    UI.message("Group #{group.id} currently internal=#{group.is_internal_group}")
    begin
      Spaceship::ConnectAPI.patch_group(group_id: group.id, attributes: { isInternalGroup: true, hasAccessToAllBuilds: true })
      UI.success("Patched to internal")
    rescue => e
      UI.error("Patch failed: #{e.message}")
    end
  end

  desc "Delete duplicate beta groups (keep one)"
  lane :cleanup_groups do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    groups = app.get_beta_groups.select { |g| g.name == "Internal Testers" }
    keeper = groups.last  # the one with build + tester
    groups[0...-1].each do |g|
      UI.message("Deleting duplicate group #{g.id}")
      g.delete! rescue UI.message("delete failed: #{$!.message}")
    end
    UI.success("Kept group: #{keeper.id}")
  end

  desc "Add internal testers + assign latest build"
  lane :testers do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")

    groups = app.get_beta_groups
    UI.message("All groups: #{groups.map { |g| "#{g.name}(internal=#{g.is_internal_group})" }.join(', ')}")
    group = groups.find { |g| g.is_internal_group }
    unless group
      UI.message("Creating internal beta group")
      group = app.create_beta_group(group_name: "Internal Testers", is_internal_group: true) rescue app.create_beta_group(group_name: "Internal Testers")
    end
    UI.success("Group: #{group.name} (#{group.id})")

    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
    UI.message("Latest build: #{build.version} state=#{build.processing_state}")

    # Set export compliance (no encryption)
    begin
      Spaceship::ConnectAPI.patch_builds(build_id: build.id, attributes: { usesNonExemptEncryption: false })
      UI.success("Export compliance set")
    rescue => e
      UI.message("Compliance: #{e.message}")
    end

    # Assign build to group
    begin
      build.add_beta_groups(beta_groups: [group])
      UI.success("Build assigned to group")
    rescue => e
      UI.message("Group assignment: #{e.message}")
    end

    # Create + add tester
    email = "spencerdhill@protonmail.com"
    begin
      tester = Spaceship::ConnectAPI.post_beta_tester_assignment(
        beta_group_ids: [group.id],
        attributes: { email: email, firstName: "Spencer", lastName: "Hill" }
      )
      UI.success("Tester added: #{email}")
    rescue => e
      UI.message("Tester add via assignment: #{e.message}")
      # Try alternative: post tester then link to group
      begin
        client = Spaceship::ConnectAPI::TestFlight::Client.instance
        body = { data: { type: "betaTesters", attributes: { email: email, firstName: "Spencer", lastName: "Hill" }, relationships: { betaGroups: { data: [{ type: "betaGroups", id: group.id }] } } } }
        client.post("betaTesters", body)
        UI.success("Tester added via direct POST")
      rescue => e2
        UI.error("All tester methods failed: #{e2.message}")
      end
    end
  end

  desc "Fetch Beta App Review feedback / rejection notes"
  lane :beta_review_status do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
    UI.message("Build #{build.version}: processing=#{build.processing_state}")
    # Beta App Review Submissions
    resp = Spaceship::ConnectAPI.tunes_request_client.get("v1/builds/#{build.id}/betaAppReviewSubmission")
    UI.message("beta app review submission: #{resp.body.inspect}")
    # Try messages / notes via direct API
    begin
      msgs = Spaceship::ConnectAPI.tunes_request_client.get("v1/apps/#{app.id}/appStoreReviewSubmissions")
      UI.message("messages: #{msgs.body.inspect[0..2000]}")
    rescue => e
      UI.message("msgs err: #{e.message[0..200]}")
    end
  end

  desc "Check App Store review submission status"
  lane :review_status do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    subs = Spaceship::ConnectAPI.get_review_submissions(app_id: app.id).to_models
    subs.each { |s| UI.message("review submission #{s.id}: state=#{s.state} submitted=#{s.submitted_date}") }
    version = app.get_edit_app_store_version(platform: "MAC_OS") || app.get_latest_app_store_version(platform: "MAC_OS")
    UI.message("version 1.0 state=#{version&.app_store_state}") if version
    # Beta review for the build
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
    UI.message("build #{build.version}: processing=#{build.processing_state}")
  end

  desc "Check TestFlight build status"
  lane :check do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    builds = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 5)
    builds.each { |b| UI.message("build #{b.version}: processing=#{b.processing_state} uploaded=#{b.uploaded_date}") }
  end

  desc "Cancel any in-flight App Store review submission"
  lane :cancel_review do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    subs = Spaceship::ConnectAPI.get_review_submissions(app_id: app.id).to_models
    subs.each do |s|
      next unless ["READY_FOR_REVIEW","WAITING_FOR_REVIEW","IN_REVIEW"].include?(s.state)
      UI.message("Canceling submission #{s.id} (#{s.state})")
      Spaceship::ConnectAPI.patch_review_submission(review_submission_id: s.id, attributes: { canceled: true }) rescue UI.message($!.message[0..200])
    end
    # Also rename app record so the app's display name in ASC is updated
    begin
      Spaceship::ConnectAPI.patch_app(app_id: app.id, attributes: { name: "Battery Charged Notification" })
      UI.success("App display name updated")
    rescue => e
      UI.message("app name: #{e.message[0..200]}")
    end
  end

  desc "Submit latest build for Beta App Review (build 2+)"
  lane :submit_beta_v2 do
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token
    app = Spaceship::ConnectAPI::App.find("com.spencerhill.fullbatteryalert")
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 1).first
    UI.message("Submitting build #{build.version} (#{build.processing_state}) for Beta review")
    begin
      Spaceship::ConnectAPI.post_beta_build_localizations(build_id: build.id, attributes: { locale: "en-US", whatsNew: "Renamed app to Battery Charged Notification to comply with Apple trademark guidance." })
    rescue
    end
    Spaceship::ConnectAPI.post_beta_app_review_submissions(build_id: build.id)
    UI.success("Beta review submitted for build #{build.version}")
  end

  desc "Re-upload existing pkg to TestFlight"
  lane :reupload do
    upload_to_testflight(
      api_key: API_KEY.call,
      pkg: "build/fastlane/Battery Charged Notification.pkg",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Create Mac Installer Distribution cert (needed for .pkg signing on macOS app-store export)"
  lane :installer_cert do
    require 'spaceship'
    require 'openssl'
    require 'base64'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: "XG3FW9LT9Q",
      issuer_id: "178bab61-1c45-4f62-9525-55f8ed15a98d",
      filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XG3FW9LT9Q.p8")
    )
    Spaceship::ConnectAPI.token = token

    cert_type = "MAC_INSTALLER_DISTRIBUTION"
    existing = Spaceship::ConnectAPI::Certificate.all.select { |c| c.certificate_type == cert_type }
    if existing.any?
      UI.success("Mac Installer Distribution cert already exists: #{existing.first.id}")
      cert = existing.first
    else
      UI.message("Generating CSR + Mac Installer Distribution cert...")
      key = OpenSSL::PKey::RSA.new(2048)
      csr = OpenSSL::X509::Request.new
      csr.version = 0
      csr.subject = OpenSSL::X509::Name.new([["CN", "Mac Installer Distribution", OpenSSL::ASN1::UTF8STRING]])
      csr.public_key = key.public_key
      csr.sign(key, OpenSSL::Digest::SHA256.new)

      cert = Spaceship::ConnectAPI::Certificate.create(
        certificate_type: cert_type,
        csr_content: csr.to_pem
      )

      # Save private key + cert as p12, import to keychain
      certs_dir = File.expand_path("fastlane/certs")
      FileUtils.mkdir_p(certs_dir)
      key_path = "#{certs_dir}/#{cert.id}.key"
      cer_path = "#{certs_dir}/#{cert.id}.cer"
      p12_path = "#{certs_dir}/#{cert.id}.p12"
      File.write(key_path, key.to_pem)
      File.binwrite(cer_path, Base64.decode64(cert.certificate_content))

      x509 = OpenSSL::X509::Certificate.new(File.binread(cer_path))
      p12 = OpenSSL::PKCS12.create("", "Mac Installer Distribution", key, x509)
      File.binwrite(p12_path, p12.to_der)

      sh("security import #{p12_path.shellescape} -P '' -A -t cert -f pkcs12 -k #{File.expand_path('~/Library/Keychains/login.keychain-db').shellescape}")
      UI.success("Created Mac Installer Distribution cert: #{cert.id}")
    end
  end

  desc "Create Apple Distribution cert + App Store provisioning profile"
  lane :signing do
    api_key = API_KEY.call
    get_certificates(
      api_key: api_key,
      development: false,
      platform: "macos",
      generate_apple_certs: true,
      output_path: "fastlane/certs"
    )
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.spencerhill.fullbatteryalert",
      platform: "macos",
      developer_id: false,
      output_path: "fastlane/profiles"
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = API_KEY.call
    get_certificates(
      api_key: api_key,
      development: false,
      platform: "macos",
      generate_apple_certs: true,
      output_path: "fastlane/certs"
    )
    profile = get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.spencerhill.fullbatteryalert",
      platform: "macos",
      developer_id: false,
      output_path: "fastlane/profiles"
    )
    profile_name = lane_context[SharedValues::SIGH_NAME] || ENV["sigh_com.spencerhill.fullbatteryalert_macos"]
    build_mac_app(
      project: "FullBatteryAlert.xcodeproj",
      scheme: "FullBatteryAlert",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.spencerhill.fullbatteryalert" => profile_name
        }
      },
      output_directory: "build/fastlane",
      output_name: "Battery Charged Notification"
    )
    upload_to_testflight(
      api_key: api_key,
      pkg: "build/fastlane/Battery Charged Notification.pkg",
      skip_waiting_for_build_processing: true
    )
  end
end
